# Application
APP_ENV=development
APP_NAME=gnha-services
PORT=8080

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gnha_dev?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# JWT
JWT_SECRET=change-me-in-production-use-a-strong-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Logging
LOG_LEVEL=debug

# Observability (SigNoz)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# SMTP (Mailpit in development, AWS SES or similar in production)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@app.local
# Leave empty for dev (Mailpit); set for production
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ALIAS=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
