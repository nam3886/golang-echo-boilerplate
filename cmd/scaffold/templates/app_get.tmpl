package app

import (
	"context"
	"fmt"

	"go.opentelemetry.io/otel"

	"{{.GoModule}}/internal/modules/{{.Name}}/domain"
	sharederr "{{.GoModule}}/internal/shared/errors"
)

// Get{{.NameTitle}}Handler handles fetching a single {{.Name}}.
type Get{{.NameTitle}}Handler struct {
	repo domain.{{.NameTitle}}Repository
}

// NewGet{{.NameTitle}}Handler constructs the handler.
func NewGet{{.NameTitle}}Handler(repo domain.{{.NameTitle}}Repository) *Get{{.NameTitle}}Handler {
	return &Get{{.NameTitle}}Handler{repo: repo}
}

// Handle returns a {{.Name}} by ID.
func (h *Get{{.NameTitle}}Handler) Handle(ctx context.Context, id string) (*domain.{{.NameTitle}}, error) {
	ctx, span := otel.Tracer("{{.Name}}").Start(ctx, "Get{{.NameTitle}}Handler.Handle")
	defer span.End()

	if id == "" {
		return nil, sharederr.New(sharederr.CodeInvalidArgument, "{{.Name}}.id_required", "{{.Name}} ID is required")
	}
	result, err := h.repo.GetByID(ctx, domain.{{.NameID}}(id))
	if err != nil {
		return nil, fmt.Errorf("getting {{.Name}} %s: %w", id, err)
	}
	return result, nil
}
