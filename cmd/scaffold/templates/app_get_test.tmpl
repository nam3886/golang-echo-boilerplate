func TestGet{{.NameTitle}}Handler_Success(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	now := time.Now()
	entity := domain.Reconstitute(domain.{{.NameID}}("entity-id-1"), "Test Name", now, now, nil)
	mockRepo.EXPECT().
		GetByID(gomock.Any(), domain.{{.NameID}}("entity-id-1")).
		Return(entity, nil)

	handler := NewGet{{.NameTitle}}Handler(mockRepo)
	got, err := handler.Handle(context.Background(), "entity-id-1")
	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if got == nil {
		t.Fatal("expected entity, got nil")
	}
}

