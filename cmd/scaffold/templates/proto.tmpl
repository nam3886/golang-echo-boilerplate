  rpc List{{.NamePluralTitle}}(List{{.NamePluralTitle}}Request) returns (List{{.NamePluralTitle}}Response);
  rpc Create{{.NameTitle}}(Create{{.NameTitle}}Request) returns (Create{{.NameTitle}}Response);
  rpc Update{{.NameTitle}}(Update{{.NameTitle}}Request) returns (Update{{.NameTitle}}Response);
  rpc Delete{{.NameTitle}}(Delete{{.NameTitle}}Request) returns (Delete{{.NameTitle}}Response);
}

message {{.NameTitle}} {
