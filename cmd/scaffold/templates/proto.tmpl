}

message Create{{.NameTitle}}Response {
  {{.NameTitle}} {{.Name}} = 1;
}

message Get{{.NameTitle}}Request {
  string id = 1 [(buf.validate.field).string.uuid = true];
}

message Get{{.NameTitle}}Response {
  {{.NameTitle}} {{.Name}} = 1;
}

message List{{.NamePluralTitle}}Request {
