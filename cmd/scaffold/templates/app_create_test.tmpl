func TestCreate{{.NameTitle}}Handler_Success(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	mockRepo.EXPECT().
		Create(gomock.Any(), gomock.Any()).
		Return(nil)

	recorder := &testutil.CapturingPublisher{}
	bus := events.NewEventBus(recorder)
	handler := NewCreate{{.NameTitle}}Handler(mockRepo, bus)

	entity, err := handler.Handle(context.Background(), Create{{.NameTitle}}Cmd{
		Name: "Test Name",
	})
	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if entity.Name() != "Test Name" {
		t.Errorf("expected name Test Name, got %s", entity.Name())
	}
	if len(recorder.Messages) == 0 || recorder.Messages[0].Topic != domain.Topic{{.NameTitle}}Created {
		got := ""
		if len(recorder.Messages) > 0 {
			got = recorder.Messages[0].Topic
		}
		t.Errorf("expected topic %s, got %s", domain.Topic{{.NameTitle}}Created, got)
	}
}

func TestCreate{{.NameTitle}}Handler_EmptyName(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	bus := events.NewEventBus(&testutil.NoopPublisher{})
	handler := NewCreate{{.NameTitle}}Handler(mockRepo, bus)

	_, err := handler.Handle(context.Background(), Create{{.NameTitle}}Cmd{
		Name: "",
	})
	if err == nil {
		t.Fatal("expected error for empty name")
	}
}

func TestCreate{{.NameTitle}}Handler_RepoError(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	mockRepo.EXPECT().
		Create(gomock.Any(), gomock.Any()).
		Return(fmt.Errorf("connection refused"))

	bus := events.NewEventBus(&testutil.NoopPublisher{})
	handler := NewCreate{{.NameTitle}}Handler(mockRepo, bus)

	_, err := handler.Handle(context.Background(), Create{{.NameTitle}}Cmd{
		Name: "Test Name",
	})
	if err == nil {
		t.Fatal("expected error when repo.Create fails")
	}
}

func TestCreate{{.NameTitle}}Handler_EventPublishFailure_DoesNotFail(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	mockRepo.EXPECT().
		Create(gomock.Any(), gomock.Any()).
		Return(nil)

	bus := events.NewEventBus(&testutil.FailPublisher{})
	handler := NewCreate{{.NameTitle}}Handler(mockRepo, bus)

	entity, err := handler.Handle(context.Background(), Create{{.NameTitle}}Cmd{
		Name: "Test Name",
	})
	if err != nil {
		t.Fatalf("expected no error even when publish fails, got %v", err)
	}
	if entity == nil {
		t.Fatal("expected entity, got nil")
	}
}
