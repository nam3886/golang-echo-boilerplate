package app

import (
	"context"
	"fmt"
	"log/slog"

	"go.opentelemetry.io/otel"

	"{{.GoModule}}/internal/modules/{{.Name}}/domain"
	"{{.GoModule}}/internal/shared/auth"
	"{{.GoModule}}/internal/shared/events"
	sharederr "{{.GoModule}}/internal/shared/errors"
	"{{.GoModule}}/internal/shared/netutil"
)

// Update{{.NameTitle}}Cmd holds input for updating a {{.Name}}.
type Update{{.NameTitle}}Cmd struct {
	ID   string
	Name *string
}

// Update{{.NameTitle}}Handler handles {{.Name}} updates via closure-based UoW.
// Required: repo, bus
type Update{{.NameTitle}}Handler struct {
	repo domain.{{.NameTitle}}Repository
	bus  events.EventPublisher
}

// NewUpdate{{.NameTitle}}Handler constructs the handler.
// Panics on nil required deps so misconfigured DI wiring fails at startup, not at runtime.
func NewUpdate{{.NameTitle}}Handler(repo domain.{{.NameTitle}}Repository, bus events.EventPublisher) *Update{{.NameTitle}}Handler {
	if repo == nil {
		panic("NewUpdate{{.NameTitle}}Handler: repo must not be nil")
	}
	if bus == nil {
		panic("NewUpdate{{.NameTitle}}Handler: bus must not be nil")
	}
	return &Update{{.NameTitle}}Handler{repo: repo, bus: bus}
}

// Handle applies partial updates to a {{.NameTitle}} within a transaction.
// If no fields are provided (all nil), returns current state without acquiring lock.
func (h *Update{{.NameTitle}}Handler) Handle(ctx context.Context, cmd Update{{.NameTitle}}Cmd) (*domain.{{.NameTitle}}, error) {
	ctx, span := otel.Tracer("{{.Name}}").Start(ctx, "Update{{.NameTitle}}Handler.Handle")
	defer span.End()

	if cmd.ID == "" {
		return nil, sharederr.New(sharederr.CodeInvalidArgument, "{{.Name}}.id_required", "{{.Name}} ID is required")
	}
	// Skip DB lock entirely when no fields are provided.
	if cmd.Name == nil {
		entity, err := h.repo.GetByID(ctx, domain.{{.NameID}}(cmd.ID))
		if err != nil {
			return nil, err
		}
		return entity, nil
	}
	var updated *domain.{{.NameTitle}}
	var changedFields []string
	err := h.repo.Update(ctx, domain.{{.NameID}}(cmd.ID), func(entity *domain.{{.NameTitle}}) error {
		changedFields = nil
		if cmd.Name != nil && *cmd.Name != entity.Name() {
			if err := entity.ChangeName(*cmd.Name); err != nil {
				return err
			}
			changedFields = append(changedFields, "name")
		}
		updated = entity
		if len(changedFields) == 0 {
			return sharederr.ErrNoChange()
		}
		return nil
	})
	if err != nil {
		return nil, fmt.Errorf("update_{{.Name}}: %w", err)
	}
	if updated == nil {
		return nil, fmt.Errorf("update_{{.Name}}: repository did not populate entity")
	}

	// Skip event if nothing was actually changed.
	if len(changedFields) == 0 {
		return updated, nil
	}

	if err := h.bus.Publish(ctx, domain.Topic{{.NameTitle}}Updated, domain.{{.NameTitle}}UpdatedEvent{
		Version:         1,
		{{.NameTitle}}ID: cmd.ID,
		Name:            updated.Name(),
		ActorID:         auth.ActorIDFromContext(ctx),
		ChangedFields:   changedFields,
		IPAddress:       netutil.GetClientIP(ctx),
		At:              updated.UpdatedAt(),
	}); err != nil {
		slog.ErrorContext(ctx, "failed to publish {{.Name}}.updated event",
			"{{.Name}}_id", cmd.ID, "err", err)
	}

	return updated, nil
}
