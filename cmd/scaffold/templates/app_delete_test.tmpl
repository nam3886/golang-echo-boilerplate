func deleted{{.NameTitle}}Fixture() *domain.{{.NameTitle}} {
	now := time.Now()
	return domain.Reconstitute("entity-id-1", "Test Name", now, now, &now)
}

func TestDelete{{.NameTitle}}Handler_Success(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	mockRepo.EXPECT().
		SoftDelete(gomock.Any(), domain.{{.NameID}}("entity-id-1")).
		Return(deleted{{.NameTitle}}Fixture(), nil)

	recorder := &testutil.CapturingPublisher{}
	bus := events.NewEventBus(recorder)
	handler := NewDelete{{.NameTitle}}Handler(mockRepo, bus)
	err := handler.Handle(context.Background(), "entity-id-1")
	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if len(recorder.Messages) == 0 || recorder.Messages[0].Topic != domain.TopicDeleted {
		t.Error("expected delete event to be published")
	}
}

func TestDelete{{.NameTitle}}Handler_NotFound(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	mockRepo.EXPECT().
		SoftDelete(gomock.Any(), domain.{{.NameID}}("missing-id")).
		Return(nil, sharederr.ErrNotFound())

	bus := events.NewEventBus(&testutil.NoopPublisher{})
	handler := NewDelete{{.NameTitle}}Handler(mockRepo, bus)
	err := handler.Handle(context.Background(), "missing-id")
	if err == nil {
		t.Fatal("expected not found error, got nil")
	}
}

