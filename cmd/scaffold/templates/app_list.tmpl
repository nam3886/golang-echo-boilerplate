}

// NewList{{.NamePluralTitle}}Handler constructs the handler.
func NewList{{.NamePluralTitle}}Handler(repo domain.{{.NameTitle}}Repository) *List{{.NamePluralTitle}}Handler {
	return &List{{.NamePluralTitle}}Handler{repo: repo}
