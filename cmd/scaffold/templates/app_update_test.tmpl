package app

import (
	"context"
	"fmt"
	"testing"

	"{{.GoModule}}/internal/modules/{{.Name}}/domain"
	"{{.GoModule}}/internal/shared/events"
	"{{.GoModule}}/internal/shared/mocks"
	"{{.GoModule}}/internal/shared/testutil"
	"go.uber.org/mock/gomock"
