func TestUpdate{{.NameTitle}}Handler_Success(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	mockRepo.EXPECT().
		Update(gomock.Any(), domain.{{.NameID}}("entity-id-1"), gomock.Any()).
		DoAndReturn(func(_ context.Context, _ domain.{{.NameID}}, fn func(*domain.{{.NameTitle}}) error) error {
			entity := &domain.{{.NameTitle}}{}
			return fn(entity)
		})

	name := "Updated Name"
	bus := events.NewEventBus(&testutil.NoopPublisher{})
	handler := NewUpdate{{.NameTitle}}Handler(mockRepo, bus)
	_, err := handler.Handle(context.Background(), Update{{.NameTitle}}Cmd{
		ID:   "entity-id-1",
		Name: &name,
	})
	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
}

func TestUpdate{{.NameTitle}}Handler_EmptyID(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	bus := events.NewEventBus(&testutil.NoopPublisher{})
	handler := NewUpdate{{.NameTitle}}Handler(mockRepo, bus)
	_, err := handler.Handle(context.Background(), Update{{.NameTitle}}Cmd{ID: ""})
	if err == nil {
		t.Fatal("expected error for empty id")
	}
}

func TestUpdate{{.NameTitle}}Handler_RepoFailure(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	mockRepo.EXPECT().
		Update(gomock.Any(), gomock.Any(), gomock.Any()).
		Return(fmt.Errorf("db error"))

	name := "New Name"
	bus := events.NewEventBus(&testutil.NoopPublisher{})
	handler := NewUpdate{{.NameTitle}}Handler(mockRepo, bus)
	_, err := handler.Handle(context.Background(), Update{{.NameTitle}}Cmd{
		ID:   "entity-id-1",
		Name: &name,
	})
	if err == nil {
		t.Fatal("expected error from repo failure")
	}
}
