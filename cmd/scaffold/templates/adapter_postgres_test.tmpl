func TestPg{{.NameTitle}}Repository_List_Pagination(t *testing.T) {
	repo := setupRepo(t)
	ctx := context.Background()

	names := []string{"Item 1", "Item 2", "Item 3"}
	for _, name := range names {
		entity := createTest{{.NameTitle}}(t, name)
		if err := repo.Create(ctx, entity); err != nil {
			t.Fatalf("Create %s: %v", name, err)
		}
	}

	// Page 1 with pageSize=2 → should get 2 items + total=3
	result, err := repo.List(ctx, 1, 2)
	if err != nil {
		t.Fatalf("List: %v", err)
	}
	if len(result.{{.NamePluralTitle}}) != 2 {
		t.Errorf("expected 2 items, got %d", len(result.{{.NamePluralTitle}}))
	}
	if result.Total != 3 {
		t.Errorf("expected total=3, got %d", result.Total)
	}

	// Page 2 → should get 1 item + total=3
	result2, err := repo.List(ctx, 2, 2)
	if err != nil {
		t.Fatalf("List page 2: %v", err)
	}
	if len(result2.{{.NamePluralTitle}}) != 1 {
		t.Errorf("expected 1 item on page 2, got %d", len(result2.{{.NamePluralTitle}}))
	}
	if result2.Total != 3 {
		t.Errorf("expected total=3, got %d", result2.Total)
	}
}
