func TestPg{{.NameTitle}}Repository_Update_Success(t *testing.T) {
	repo := setupRepo(t)
	ctx := context.Background()

	entity := createTest{{.NameTitle}}(t, "Original Name")
	if err := repo.Create(ctx, entity); err != nil {
		t.Fatalf("Create: %v", err)
	}

	newName := "Updated Name"
	// TODO: Replace ChangeName with your entity's actual mutation method if different.
	err := repo.Update(ctx, entity.ID(), func(e *domain.{{.NameTitle}}) error {
		return e.ChangeName(newName)
	})
	if err != nil {
		t.Fatalf("Update: %v", err)
	}

	got, err := repo.GetByID(ctx, entity.ID())
	if err != nil {
		t.Fatalf("GetByID after Update: %v", err)
	}
	if got.Name() != newName {
		t.Errorf("expected name=%q, got %q", newName, got.Name())
	}
}

