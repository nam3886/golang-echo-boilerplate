	"github.com/jackc/pgx/v5/pgtype"
	"github.com/jackc/pgx/v5/pgxpool"
)

// Pg{{.NameTitle}}Repository implements domain.{{.NameTitle}}Repository using pgx + sqlc.
type Pg{{.NameTitle}}Repository struct {
	pool *pgxpool.Pool
}

// NewPg{{.NameTitle}}Repository constructs the repository.
func NewPg{{.NameTitle}}Repository(pool *pgxpool.Pool) *Pg{{.NameTitle}}Repository {
	return &Pg{{.NameTitle}}Repository{pool: pool}
}

func (r *Pg{{.NameTitle}}Repository) GetByID(ctx context.Context, id domain.{{.NameID}}) (*domain.{{.NameTitle}}, error) {
	uid, err := parse{{.NameTitle}}ID(id)
	if err != nil {
		return nil, err
	}
	q := sqlcgen.New(r.pool)
	row, err := q.Get{{.NameTitle}}ByID(ctx, uid)
	if err != nil {
		if errors.Is(err, pgx.ErrNoRows) {
			return nil, sharederr.ErrNotFound
		}
		return nil, fmt.Errorf("getting {{.Name}} by id: %w", err)
	}
	return toDomain(row), nil
}

func (r *Pg{{.NameTitle}}Repository) List(ctx context.Context, limit int, cursor string) ([]*domain.{{.NameTitle}}, string, bool, error) {
	q := sqlcgen.New(r.pool)

	// Fetch limit+1 to detect whether more pages exist.
	params := sqlcgen.List{{.NamePluralTitle}}Params{Limit: int32(limit + 1)}
	if cursor != "" {
		decoded, err := decodeCursor(cursor)
		if err == nil {
			params.CursorCreatedAt = pgtype.Timestamptz{Time: decoded.T, Valid: true}
			params.CursorID = pgtype.UUID{Bytes: decoded.U, Valid: true}
		}
	}

	rows, err := q.List{{.NamePluralTitle}}(ctx, params)
	if err != nil {
		return nil, "", false, fmt.Errorf("listing {{.NamePlural}}: %w", err)
	}

	items := make([]*domain.{{.NameTitle}}, 0, len(rows))
	for _, row := range rows {
		items = append(items, toDomain(row))
	}

	hasMore := len(items) > limit
	if hasMore {
		items = items[:limit]
	}

	var nextCursor string
	if hasMore && len(items) > 0 {
		last := items[len(items)-1]
		if uid, err := uuid.Parse(string(last.ID())); err == nil {
			nextCursor = encodeCursor(last.CreatedAt(), uid)
		}
	}

	return items, nextCursor, hasMore, nil
}

func (r *Pg{{.NameTitle}}Repository) Create(ctx context.Context, entity *domain.{{.NameTitle}}) error {
	uid, err := parse{{.NameTitle}}ID(entity.ID())
	if err != nil {
		return err
	}
	q := sqlcgen.New(r.pool)
	// TODO: Extend Create{{.NameTitle}}Params with all required columns for this module.
	// Always use explicit column lists in INSERT statements (never INSERT INTO t VALUES (...))
	// so that schema additions are backward-compatible and sqlc generates type-safe structs.
	_, err = q.Create{{.NameTitle}}(ctx, sqlcgen.Create{{.NameTitle}}Params{
		ID:   uid,
		Name: entity.Name(),
	})
	if err != nil {
		return fmt.Errorf("inserting {{.Name}}: %w", err)
	}
	return nil
}

func (r *Pg{{.NameTitle}}Repository) Update(ctx context.Context, id domain.{{.NameID}}, fn func(*domain.{{.NameTitle}}) error) error {
	uid, err := parse{{.NameTitle}}ID(id)
	if err != nil {
		return err
	}

	tx, err := r.pool.Begin(ctx)
	if err != nil {
		return fmt.Errorf("beginning transaction: %w", err)
	}
	defer tx.Rollback(ctx)

	q := sqlcgen.New(tx)
	row, err := q.Get{{.NameTitle}}ByIDForUpdate(ctx, uid)
	if err != nil {
		if errors.Is(err, pgx.ErrNoRows) {
			return sharederr.ErrNotFound
		}
		return fmt.Errorf("fetching {{.Name}} for update: %w", err)
	}

	entity := toDomain(row)
	if err := fn(entity); err != nil {
		return err
	}

	name := entity.Name()
	_, err = q.Update{{.NameTitle}}(ctx, sqlcgen.Update{{.NameTitle}}Params{
		ID:   uid,
		Name: pgtype.Text{String: name, Valid: true},
	})
	if err != nil {
		return fmt.Errorf("updating {{.Name}}: %w", err)
	}

	return tx.Commit(ctx)
}

func (r *Pg{{.NameTitle}}Repository) SoftDelete(ctx context.Context, id domain.{{.NameID}}) error {
	uid, err := parse{{.NameTitle}}ID(id)
	if err != nil {
		return err
	}
	q := sqlcgen.New(r.pool)
	rows, err := q.SoftDelete{{.NameTitle}}(ctx, uid)
	if err != nil {
		return fmt.Errorf("soft deleting {{.Name}}: %w", err)
	}
	if rows == 0 {
		return sharederr.ErrNotFound
	}
	return nil
}

// parse{{.NameTitle}}ID safely parses a domain.{{.NameID}} into a uuid.UUID.
func parse{{.NameTitle}}ID(id domain.{{.NameID}}) (uuid.UUID, error) {
	uid, err := uuid.Parse(string(id))
	if err != nil {
		return uuid.UUID{}, sharederr.New(sharederr.CodeInvalidArgument, "invalid {{.Name}} ID format")
	}
	return uid, nil
}

// toDomain converts a sqlc row to a domain entity.
func toDomain(row sqlcgen.{{.NameTitle}}) *domain.{{.NameTitle}} {
	var deletedAt *time.Time
	if row.DeletedAt.Valid {
		deletedAt = &row.DeletedAt.Time
	}
	return domain.Reconstitute(
		domain.{{.NameID}}(row.ID.String()),
		row.Name,
		row.CreatedAt, row.UpdatedAt, deletedAt,
	)
}

// Cursor helpers for keyset pagination.
type cursorPayload struct {
	T time.Time `json:"t"`
	U uuid.UUID `json:"u"`
}

func encodeCursor(t time.Time, id uuid.UUID) string {
	data, _ := json.Marshal(cursorPayload{T: t, U: id})
	return base64.URLEncoding.EncodeToString(data)
}

func decodeCursor(cursor string) (*cursorPayload, error) {
	data, err := base64.URLEncoding.DecodeString(cursor)
	if err != nil {
		return nil, err
	}
	var c cursorPayload
	if err := json.Unmarshal(data, &c); err != nil {
		return nil, err
	}
	return &c, nil
}
