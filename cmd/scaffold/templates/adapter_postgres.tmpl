// Pg{{.NameTitle}}Repository implements domain.{{.NameTitle}}Repository using pgx + sqlc.
type Pg{{.NameTitle}}Repository struct {
	pool *pgxpool.Pool
}

// NewPg{{.NameTitle}}Repository constructs the repository.
func NewPg{{.NameTitle}}Repository(pool *pgxpool.Pool) *Pg{{.NameTitle}}Repository {
	return &Pg{{.NameTitle}}Repository{pool: pool}
}

// GetByID returns a single {{.Name}} by its ID.
func (r *Pg{{.NameTitle}}Repository) GetByID(ctx context.Context, id domain.{{.NameID}}) (*domain.{{.NameTitle}}, error) {
	uid, err := parse{{.NameTitle}}ID(id)
	if err != nil {
		return nil, err
	}
	q := sqlcgen.New(r.pool)
	row, err := q.Get{{.NameTitle}}ByID(ctx, uid)
	if err != nil {
		if errors.Is(err, pgx.ErrNoRows) {
			return nil, sharederr.ErrNotFound()
		}
		return nil, fmt.Errorf("getting {{.Name}} by id: %w", err)
	}
	return toDomain(row), nil
}

// List returns a paginated list of {{.NamePlural}} using offset pagination.
func (r *Pg{{.NameTitle}}Repository) List(ctx context.Context, page, pageSize int) (domain.ListResult, error) {
	q := sqlcgen.New(r.pool)

	offset := (page - 1) * pageSize
	if offset > math.MaxInt32 || pageSize > math.MaxInt32 {
		return domain.ListResult{}, sharederr.New(sharederr.CodeInvalidArgument, "{{.Name}}.invalid_pagination", "pagination values too large")
	}
	rows, err := q.List{{.NamePluralTitle}}(ctx, sqlcgen.List{{.NamePluralTitle}}Params{
		Limit:  int32(pageSize),
		Offset: int32(offset),
	})
	if err != nil {
		return domain.ListResult{}, fmt.Errorf("listing {{.NamePlural}}: %w", err)
	}

	total, err := q.Count{{.NamePluralTitle}}(ctx)
	if err != nil {
		return domain.ListResult{}, fmt.Errorf("counting {{.NamePlural}}: %w", err)
	}

	items := make([]*domain.{{.NameTitle}}, 0, len(rows))
	for _, row := range rows {
		items = append(items, toDomain(row))
	}

	return domain.ListResult{
		{{.NamePluralTitle}}: items,
		Total:               int(total),
	}, nil
}

// Create persists a new {{.Name}}.
func (r *Pg{{.NameTitle}}Repository) Create(ctx context.Context, entity *domain.{{.NameTitle}}) error {
	uid, err := parse{{.NameTitle}}ID(entity.ID())
	if err != nil {
		return err
	}
	q := sqlcgen.New(r.pool)
	// TODO: Extend Create{{.NameTitle}}Params with all required columns for this module.
	// Always use explicit column lists in INSERT statements (never INSERT INTO t VALUES (...))
	// so that schema additions are backward-compatible and sqlc generates type-safe structs.
	row, err := q.Create{{.NameTitle}}(ctx, sqlcgen.Create{{.NameTitle}}Params{
		ID:   uid,
		Name: entity.Name(),
	})
	if err != nil {
		// TODO: If this entity has unique constraints (e.g. email, slug), handle
		// pgconn.PgError code "23505" and map to a domain error:
		//   var pgErr *pgconn.PgError
		//   if errors.As(err, &pgErr) && pgErr.Code == "23505" {
		//       return domain.ErrAlreadyExists()
		//   }
		return fmt.Errorf("inserting {{.Name}}: %w", err)
	}
	// Overwrite entity with DB-authoritative timestamps (created_at, updated_at).
	// WARNING: If this entity has sensitive fields (e.g. hashed password) not included
	// in the RETURNING clause, preserve them before overwriting. See the user module's
	// toDomainFromCreateRow(row, entity.SensitiveField()) pattern as reference.
	*entity = *toDomain(row)
	return nil
}

// Update fetches, mutates (via fn), and persists a {{.Name}} inside a transaction.
func (r *Pg{{.NameTitle}}Repository) Update(ctx context.Context, id domain.{{.NameID}}, fn func(*domain.{{.NameTitle}}) error) error {
	uid, err := parse{{.NameTitle}}ID(id)
	if err != nil {
		return err
	}

	tx, err := r.pool.Begin(ctx)
	if err != nil {
		return fmt.Errorf("beginning transaction: %w", err)
	}
	defer func() { _ = tx.Rollback(ctx) }()

	q := sqlcgen.New(tx)
	row, err := q.Get{{.NameTitle}}ByIDForUpdate(ctx, uid)
	if err != nil {
		if errors.Is(err, pgx.ErrNoRows) {
			return sharederr.ErrNotFound()
		}
		return fmt.Errorf("fetching {{.Name}} for update: %w", err)
	}

	entity := toDomain(row)
	if err := fn(entity); err != nil {
		// No mutations — let the deferred Rollback release the FOR UPDATE lock.
		// Do NOT Commit here: committing a no-op update holds the row lock through
		// an unnecessary round-trip and obscures intent.
		if errors.Is(err, sharederr.ErrNoChange()) {
			return nil
		}
		return err
	}

	name := entity.Name()
	updatedRow, err := q.Update{{.NameTitle}}(ctx, sqlcgen.Update{{.NameTitle}}Params{
		ID:   uid,
		Name: pgtype.Text{String: name, Valid: true},
	})
	if err != nil {
		return fmt.Errorf("updating {{.Name}}: %w", err)
	}

	// Overwrite entity with DB-generated timestamps (e.g. updated_at = NOW()).
	// WARNING: If this entity has sensitive fields (e.g. hashed password) not included
	// in the RETURNING clause, preserve them before overwriting. See the user module's
	// toDomainFromUpdateRow(row, entity.SensitiveField()) pattern as reference.
	*entity = *toDomainFromUpdateRow(updatedRow)

	return tx.Commit(ctx)
}

// SoftDelete marks a {{.Name}} as deleted without removing the row.
func (r *Pg{{.NameTitle}}Repository) SoftDelete(ctx context.Context, id domain.{{.NameID}}) (*domain.{{.NameTitle}}, error) {
	uid, err := parse{{.NameTitle}}ID(id)
	if err != nil {
		return nil, err
	}
	q := sqlcgen.New(r.pool)
	row, err := q.SoftDelete{{.NameTitle}}(ctx, uid)
	if err != nil {
		if errors.Is(err, pgx.ErrNoRows) {
			return nil, sharederr.ErrNotFound()
		}
		return nil, fmt.Errorf("soft deleting {{.Name}}: %w", err)
	}
	return toDomain(row), nil
}
