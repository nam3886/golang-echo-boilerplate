package app

import (
	"context"
	"fmt"
	"testing"

	"{{.GoModule}}/internal/modules/{{.Name}}/domain"
	"{{.GoModule}}/internal/shared/mocks"
	"go.uber.org/mock/gomock"
)

func TestList{{.NamePluralTitle}}Handler_Success(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	mockRepo.EXPECT().
		List(gomock.Any(), 1, 20).
		Return(domain.ListResult{
			{{.NamePluralTitle}}: []*domain.{{.NameTitle}}{},
			Total:               3,
		}, nil)

	handler := NewList{{.NamePluralTitle}}Handler(mockRepo)
	result, err := handler.Handle(context.Background(), 1, 20)
	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if result.Total != 3 {
		t.Errorf("expected total=3, got %d", result.Total)
	}
}

func TestList{{.NamePluralTitle}}Handler_DefaultPageSize(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	// pageSize 0 should default to 20.
	mockRepo.EXPECT().
		List(gomock.Any(), 1, 20).
		Return(domain.ListResult{}, nil)

	handler := NewList{{.NamePluralTitle}}Handler(mockRepo)
	_, err := handler.Handle(context.Background(), 0, 0)
	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
}

func TestList{{.NamePluralTitle}}Handler_PageSizeCappedAt100(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	// pageSize > 100 should be capped at 100.
	mockRepo.EXPECT().
		List(gomock.Any(), 1, 100).
		Return(domain.ListResult{}, nil)

	handler := NewList{{.NamePluralTitle}}Handler(mockRepo)
	_, err := handler.Handle(context.Background(), 1, 200)
	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
}

func TestList{{.NamePluralTitle}}Handler_RepoError(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	mockRepo.EXPECT().
		List(gomock.Any(), 1, 20).
		Return(domain.ListResult{}, fmt.Errorf("db error"))

	handler := NewList{{.NamePluralTitle}}Handler(mockRepo)
	_, err := handler.Handle(context.Background(), 1, 20)
	if err == nil {
		t.Fatal("expected repo error, got nil")
	}
}
