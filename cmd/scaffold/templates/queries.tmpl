-- name: Get{{.NameTitle}}ByID :one
SELECT id, name, created_at, updated_at, deleted_at FROM {{.NamePlural}} WHERE id = $1 AND deleted_at IS NULL;

-- name: Get{{.NameTitle}}ByIDForUpdate :one
SELECT id, name, created_at, updated_at, deleted_at FROM {{.NamePlural}} WHERE id = $1 AND deleted_at IS NULL FOR UPDATE;

-- name: List{{.NamePluralTitle}} :many
SELECT id, name, created_at, updated_at, deleted_at FROM {{.NamePlural}}
WHERE deleted_at IS NULL
ORDER BY created_at DESC, id DESC
LIMIT $1 OFFSET $2;

-- name: Count{{.NamePluralTitle}} :one
SELECT count(*) FROM {{.NamePlural}} WHERE deleted_at IS NULL;

-- name: Create{{.NameTitle}} :one
INSERT INTO {{.NamePlural}} (id, name)
VALUES ($1, $2)
RETURNING id, name, created_at, updated_at, deleted_at;

-- name: Update{{.NameTitle}} :one
UPDATE {{.NamePlural}}
SET name = COALESCE(sqlc.narg('name'), name),
    updated_at = NOW()
WHERE id = $1 AND deleted_at IS NULL
RETURNING id, name, created_at, updated_at, deleted_at;

-- name: SoftDelete{{.NameTitle}} :one
UPDATE {{.NamePlural}} SET deleted_at = NOW(), updated_at = NOW()
WHERE id = $1 AND deleted_at IS NULL
RETURNING id, name, created_at, updated_at, deleted_at;
