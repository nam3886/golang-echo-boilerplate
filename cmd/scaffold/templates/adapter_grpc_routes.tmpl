package grpc

import (
	"net/http"

	"connectrpc.com/connect"
	"connectrpc.com/validate"
	"{{.GoModule}}/gen/proto/{{.Name}}/v1/{{.Name}}v1connect"
	"{{.GoModule}}/internal/shared/config"
	appmw "{{.GoModule}}/internal/shared/middleware"
	"github.com/labstack/echo/v4"
	"github.com/redis/go-redis/v9"
)

// TODO: After scaffolding, complete these manual steps before the code will compile:
//  1. Add the following constants to internal/shared/middleware/rbac.go:
//       Perm{{.NameTitle}}Read   Permission = "{{.Name}}:read"
//       Perm{{.NameTitle}}Write  Permission = "{{.Name}}:write"
//       Perm{{.NameTitle}}Delete Permission = "{{.Name}}:delete"
//  2. Add these permissions to the rolePermissions map in rbac.go for each applicable role.
//  3. Run: go test ./internal/shared/middleware/... -run TestRBAC

// {{.Name}}ProcedurePerms maps each {{.NameTitle}}Service procedure to its required permission.
// All procedures MUST be listed here — unmapped procedures under this service are denied (fail-closed).
var {{.Name}}ProcedurePerms = map[string]appmw.Permission{
	{{.Name}}v1connect.{{.NameTitle}}ServiceGet{{.NameTitle}}Procedure:    appmw.Perm{{.NameTitle}}Read,
	{{.Name}}v1connect.{{.NameTitle}}ServiceList{{.NamePluralTitle}}Procedure:  appmw.Perm{{.NameTitle}}Read,
	{{.Name}}v1connect.{{.NameTitle}}ServiceCreate{{.NameTitle}}Procedure: appmw.Perm{{.NameTitle}}Write,
	{{.Name}}v1connect.{{.NameTitle}}ServiceUpdate{{.NameTitle}}Procedure: appmw.Perm{{.NameTitle}}Write,
	{{.Name}}v1connect.{{.NameTitle}}ServiceDelete{{.NameTitle}}Procedure: appmw.Perm{{.NameTitle}}Delete,
}

// RegisterRoutes mounts the Connect RPC {{.NameTitle}}Service handler on Echo with auth + RBAC.
func RegisterRoutes(e *echo.Echo, handler *{{.NameTitle}}ServiceHandler, cfg *config.Config, rdb *redis.Client) {
	path, h := {{.Name}}v1connect.New{{.NameTitle}}ServiceHandler(handler,
		connect.WithInterceptors(
			appmw.RBACInterceptor({{.Name}}ProcedurePerms),
			validate.NewInterceptor(),
		),
	)

	// Mount Connect handler under auth. All permission checks are handled
	// by RBACInterceptor per procedure (fail-closed).
	g := e.Group(path, appmw.Auth(cfg, rdb))
	g.Any("*", echo.WrapHandler(http.StripPrefix(path, h)))
}
