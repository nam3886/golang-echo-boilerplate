package grpc

import (
	"net/http"

	"connectrpc.com/connect"
	"connectrpc.com/validate"
	"{{.GoModule}}/gen/proto/{{.Name}}/v1/{{.Name}}v1connect"
	"{{.GoModule}}/internal/shared/config"
	appmw "{{.GoModule}}/internal/shared/middleware"
	"github.com/labstack/echo/v4"
	"github.com/redis/go-redis/v9"
)

// RegisterRoutes mounts the Connect RPC {{.NameTitle}}Service handler on Echo with auth + RBAC.
//
// IMPORTANT: After scaffolding, add {{.Name}} module permissions to procedurePermissions
// in rbac_interceptor.go to enable per-procedure RBAC enforcement:
//   - Create{{.NameTitle}} → "{{.Name}}:write"
//   - Update{{.NameTitle}} → "{{.Name}}:write"
//   - Delete{{.NameTitle}} → "{{.Name}}:delete"
func RegisterRoutes(e *echo.Echo, handler *{{.NameTitle}}ServiceHandler, cfg *config.Config, rdb *redis.Client) {
	path, h := {{.Name}}v1connect.New{{.NameTitle}}ServiceHandler(handler,
		connect.WithInterceptors(
			appmw.RBACInterceptor(),
			validate.NewInterceptor(),
		),
	)

	// Mount Connect handler under auth + base read permission.
	// Write/delete permissions enforced by RBACInterceptor per procedure.
	// TODO: Register a typed Permission constant (e.g. Perm{{.NameTitle}}Read) in
	// internal/shared/middleware/rbac.go and replace the string literal below.
	g := e.Group(path, appmw.Auth(cfg, rdb), appmw.RequirePermission("{{.Name}}:read"))
	g.Any("*", echo.WrapHandler(http.StripPrefix(path, h)))
}
