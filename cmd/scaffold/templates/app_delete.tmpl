package app

import (
	"context"
	"fmt"
	"log/slog"

	"github.com/google/uuid"
	"go.opentelemetry.io/otel"

	"{{.GoModule}}/internal/modules/{{.Name}}/domain"
	"{{.GoModule}}/internal/shared/auth"
	"{{.GoModule}}/internal/shared/events"
	sharederr "{{.GoModule}}/internal/shared/errors"
	"{{.GoModule}}/internal/shared/netutil"
)

// Delete{{.NameTitle}}Handler handles soft-deleting a {{.Name}}.
// Required: repo, bus
type Delete{{.NameTitle}}Handler struct {
	repo domain.{{.NameTitle}}Repository
	bus  events.EventPublisher
}

// NewDelete{{.NameTitle}}Handler constructs the handler.
// Panics on nil required deps so misconfigured DI wiring fails at startup, not at runtime.
func NewDelete{{.NameTitle}}Handler(repo domain.{{.NameTitle}}Repository, bus events.EventPublisher) *Delete{{.NameTitle}}Handler {
	if repo == nil {
		panic("NewDelete{{.NameTitle}}Handler: repo must not be nil")
	}
	if bus == nil {
		panic("NewDelete{{.NameTitle}}Handler: bus must not be nil")
	}
	return &Delete{{.NameTitle}}Handler{repo: repo, bus: bus}
}

// Handle soft-deletes a {{.Name}} by ID.
func (h *Delete{{.NameTitle}}Handler) Handle(ctx context.Context, id string) error {
	ctx, span := otel.Tracer("{{.Name}}").Start(ctx, "Delete{{.NameTitle}}Handler.Handle")
	defer span.End()

	if id == "" {
		return domain.Err{{.NameTitle}}IDRequired()
	}
	entity, err := h.repo.SoftDelete(ctx, domain.{{.NameID}}(id))
	if err != nil {
		return fmt.Errorf("deleting {{.Name}} %s: %w", id, err)
	}

	if !entity.IsDeleted() {
		return fmt.Errorf("soft delete returned non-deleted {{.Name}} %s: adapter bug", id)
	}
	deletedAt := *entity.DeletedAt()

	if err := h.bus.Publish(ctx, domain.Topic{{.NameTitle}}Deleted, domain.{{.NameTitle}}DeletedEvent{
		EventID:         uuid.NewString(),
		Version:         domain.EventSchemaVersion,
		{{.NameTitle}}ID: id,
		ActorID:         auth.ActorIDFromContext(ctx),
		IPAddress:       netutil.GetClientIP(ctx),
		At:              deletedAt,
	}); err != nil {
		slog.ErrorContext(ctx, "failed to publish {{.Name}}.deleted event",
			"module", "{{.Name}}", "operation", "Delete{{.NameTitle}}Handler",
			"{{.Name}}_id", id, "error_code", "event_publish_failed",
			"retryable", true, "err", err)
	}

	return nil
}
