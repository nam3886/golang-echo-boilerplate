}

// NewDelete{{.NameTitle}}Handler constructs the handler.
func NewDelete{{.NameTitle}}Handler(repo domain.{{.NameTitle}}Repository) *Delete{{.NameTitle}}Handler {
	return &Delete{{.NameTitle}}Handler{repo: repo}
}

// Handle soft-deletes a {{.Name}} by ID.
func (h *Delete{{.NameTitle}}Handler) Handle(ctx context.Context, id string) error {
	if id == "" {
		return domain.ErrInvalidArgument()
	}
	if err := h.repo.SoftDelete(ctx, domain.{{.NameID}}(id)); err != nil {
		return err
	}

