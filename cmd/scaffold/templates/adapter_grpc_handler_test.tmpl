func build{{.NameTitle}}Handler(
	create *app.Create{{.NameTitle}}Handler,
	get *app.Get{{.NameTitle}}Handler,
	list *app.List{{.NamePluralTitle}}Handler,
	update *app.Update{{.NameTitle}}Handler,
	delete *app.Delete{{.NameTitle}}Handler,
) *grpcadapter.{{.NameTitle}}ServiceHandler {
	return grpcadapter.New{{.NameTitle}}ServiceHandler(create, get, list, update, delete)
}

func TestHandler_Create{{.NameTitle}}_Success(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	mockRepo.EXPECT().
		Create(gomock.Any(), gomock.Any()).
		Return(nil)

	bus := events.NewEventBus(&testutil.NoopPublisher{})
	create := app.NewCreate{{.NameTitle}}Handler(mockRepo, bus)
	get := app.NewGet{{.NameTitle}}Handler(mockRepo)
	list := app.NewList{{.NamePluralTitle}}Handler(mockRepo)
	update := app.NewUpdate{{.NameTitle}}Handler(mockRepo, bus)
	del := app.NewDelete{{.NameTitle}}Handler(mockRepo, bus)

	h := build{{.NameTitle}}Handler(create, get, list, update, del)

	resp, err := h.Create{{.NameTitle}}(context.Background(), connect.NewRequest(&{{.Name}}v1.Create{{.NameTitle}}Request{
		Name: "Test Name",
	}))
	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if resp.Msg.{{.NameTitle}}.Name != "Test Name" {
		t.Errorf("expected name=Test Name, got %s", resp.Msg.{{.NameTitle}}.Name)
	}
}

func TestHandler_Create{{.NameTitle}}_ValidationError(t *testing.T) {
	ctrl := gomock.NewController(t)
	mockRepo := mocks.NewMock{{.NameTitle}}Repository(ctrl)

	bus := events.NewEventBus(&testutil.NoopPublisher{})
	create := app.NewCreate{{.NameTitle}}Handler(mockRepo, bus)
	get := app.NewGet{{.NameTitle}}Handler(mockRepo)
	list := app.NewList{{.NamePluralTitle}}Handler(mockRepo)
	update := app.NewUpdate{{.NameTitle}}Handler(mockRepo, bus)
	del := app.NewDelete{{.NameTitle}}Handler(mockRepo, bus)

	h := build{{.NameTitle}}Handler(create, get, list, update, del)

	_, err := h.Create{{.NameTitle}}(context.Background(), connect.NewRequest(&{{.Name}}v1.Create{{.NameTitle}}Request{
		Name: "",
	}))
	if err == nil {
		t.Fatal("expected connect error for empty name, got nil")
	}
	var ce *connect.Error
	if !errors.As(err, &ce) {
		t.Fatalf("expected *connect.Error, got %T", err)
	}
}

