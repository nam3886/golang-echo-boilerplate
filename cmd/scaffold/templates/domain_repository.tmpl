// ListResult holds paginated results from a List query.
// Convention: use the entity-specific plural field name (e.g. Users, Products) — not Items.
type ListResult struct {
	{{.NamePluralTitle}} []*{{.NameTitle}}
	Total               int
}

// TotalPages computes the total number of pages for the given page size.
func (r ListResult) TotalPages(pageSize int) int {
	if pageSize <= 0 {
		return 0
	}
	return (r.Total + pageSize - 1) / pageSize
}

