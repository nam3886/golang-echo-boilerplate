//   - Update: TOCTOU handled via FOR UPDATE lock; concurrent updates serialized at DB level
//   - SoftDelete: atomic UPDATE RETURNING; returns deleted snapshot; Err{{.NameTitle}}NotFound if already deleted
//   - List: always retryable; returns empty slice (never nil) for no results
//
// TODO: Add domain-specific lookup methods as needed (e.g. GetByEmail, GetBySlug).
type {{.NameTitle}}Repository interface {
	// GetByID returns the entity by ID. Returns Err{{.NameTitle}}NotFound if not found.
	GetByID(ctx context.Context, id {{.NameID}}) (*{{.NameTitle}}, error)
	// List returns paginated results. Empty page returns empty slice, not nil.
	List(ctx context.Context, page, pageSize int) (ListResult, error)
