package postgres

import (
	"time"

	sqlcgen "{{.GoModule}}/gen/sqlc"
	"{{.GoModule}}/internal/modules/{{.Name}}/domain"
	sharederr "{{.GoModule}}/internal/shared/errors"
	"github.com/google/uuid"
)

// parse{{.NameTitle}}ID safely parses a domain.{{.NameID}} into a uuid.UUID.
func parse{{.NameTitle}}ID(id domain.{{.NameID}}) (uuid.UUID, error) {
	uid, err := uuid.Parse(string(id))
	if err != nil {
		return uuid.UUID{}, sharederr.New(sharederr.CodeInvalidArgument, "{{.Name}}.invalid_id", "invalid {{.Name}} ID format")
	}
	return uid, nil
}

// toDomain converts a sqlc {{.NameTitle}} row to a domain entity.
//
// WARNING: This scaffold generates a single toDomain() mapper because all generated
// queries return the same columns. If you add sensitive fields (e.g. password, secret)
// and exclude them from some RETURNING clauses, sqlc will generate distinct row types
// per query. You MUST then create per-query mapper variants:
//   - toDomainFromGetRow(), toDomainFromListRow(), toDomainFromCreateRow(), etc.
//
// Also: if Create/Update RETURNING excludes fields, preserve them before overwriting
// the entity pointer (see repo.Create pattern with password preservation).
//
// Reference: internal/modules/user/adapters/postgres/mapper.go
func toDomain(row sqlcgen.{{.NameTitle}}) *domain.{{.NameTitle}} {
	var deletedAt *time.Time
	if row.DeletedAt.Valid {
		deletedAt = &row.DeletedAt.Time
	}
	return domain.Reconstitute(
		domain.{{.NameID}}(row.ID.String()),
		row.Name,
		row.CreatedAt, row.UpdatedAt, deletedAt,
	)
}

// toDomainFromUpdateRow converts an Update{{.NameTitle}}Row to a domain entity.
// WARNING: If this entity has sensitive fields excluded from RETURNING, add a
// parameter to preserve them (see user module's toDomainFromUpdateRow(row, pwd) pattern).
func toDomainFromUpdateRow(row sqlcgen.Update{{.NameTitle}}Row) *domain.{{.NameTitle}} {
	var deletedAt *time.Time
	if row.DeletedAt.Valid {
		deletedAt = &row.DeletedAt.Time
	}
	return domain.Reconstitute(
		domain.{{.NameID}}(row.ID.String()),
		row.Name,
		row.CreatedAt, row.UpdatedAt, deletedAt,
	)
}
