package grpc

import (
	{{.Name}}v1 "{{.GoModule}}/gen/proto/{{.Name}}/v1"
	"{{.GoModule}}/internal/modules/{{.Name}}/domain"
	"{{.GoModule}}/internal/shared/connectutil"
	"google.golang.org/protobuf/types/known/timestamppb"
)

// toProto converts a domain {{.NameTitle}} to a protobuf {{.NameTitle}}.
func toProto(e *domain.{{.NameTitle}}) *{{.Name}}v1.{{.NameTitle}} {
	return &{{.Name}}v1.{{.NameTitle}}{
		Id:        string(e.ID()),
		Name:      e.Name(),
		CreatedAt: timestamppb.New(e.CreatedAt()),
		UpdatedAt: timestamppb.New(e.UpdatedAt()),
	}
}

// domainErrorToConnect maps DomainError to Connect RPC error codes.
func domainErrorToConnect(err error) error {
	return connectutil.DomainErrorToConnect(err)
}
