package domain

import (
	"time"

	"github.com/google/uuid"
)

// {{.NameID}} is a typed identifier for {{.NamePlural}}.
type {{.NameID}} string

// {{.NameTitle}} is the domain entity with encapsulated fields.
type {{.NameTitle}} struct {
	id        {{.NameID}}
	name      string
	createdAt time.Time
	updatedAt time.Time
	deletedAt *time.Time
}

// New{{.NameTitle}} creates a validated {{.NameTitle}} entity.
func New{{.NameTitle}}(name string) (*{{.NameTitle}}, error) {
	if name == "" {
		return nil, ErrNameRequired()
	}
	now := time.Now()
	return &{{.NameTitle}}{
		id:        {{.NameID}}(uuid.NewString()),
		name:      name,
		createdAt: now,
		updatedAt: now,
	}, nil
}

// Reconstitute rebuilds a {{.NameTitle}} from persistence data (no validation).
// TODO: Add all entity fields when extending the domain model.
func Reconstitute(id {{.NameID}}, name string, createdAt, updatedAt time.Time, deletedAt *time.Time) *{{.NameTitle}} {
	return &{{.NameTitle}}{
		id: id, name: name,
		createdAt: createdAt, updatedAt: updatedAt, deletedAt: deletedAt,
	}
}

// ID returns the {{.Name}} identifier.
func (e *{{.NameTitle}}) ID() {{.NameID}} { return e.id }

// Name returns the {{.Name}} name.
func (e *{{.NameTitle}}) Name() string { return e.name }

// CreatedAt returns when the {{.Name}} was created.
func (e *{{.NameTitle}}) CreatedAt() time.Time { return e.createdAt }

// UpdatedAt returns when the {{.Name}} was last updated.
func (e *{{.NameTitle}}) UpdatedAt() time.Time { return e.updatedAt }

// DeletedAt returns the soft-delete timestamp, or nil if not deleted.
func (e *{{.NameTitle}}) DeletedAt() *time.Time { return e.deletedAt }

// IsDeleted reports whether the {{.Name}} has been soft-deleted.
func (e *{{.NameTitle}}) IsDeleted() bool { return e.deletedAt != nil }

// ChangeName updates the name. No-op if unchanged.
func (e *{{.NameTitle}}) ChangeName(name string) error {
	if name == "" {
		return ErrNameRequired()
	}
	if name == e.name {
		return nil
	}
	e.name = name
	e.updatedAt = time.Now()
	return nil
}
