package domain

import (
	sharederr "{{.GoModule}}/internal/shared/errors"
)

// Module-specific domain errors — constructor functions return fresh instances
// to prevent data races when errors are wrapped concurrently.

// Err{{.NameTitle}}NotFound indicates the {{.Name}} does not exist.
func Err{{.NameTitle}}NotFound() *sharederr.DomainError {
	return sharederr.New(sharederr.CodeNotFound, "{{.Name}}.not_found", "{{.Name}} not found")
}

// ErrNameRequired indicates the name field is missing.
func ErrNameRequired() *sharederr.DomainError {
	return sharederr.New(sharederr.CodeInvalidArgument, "{{.Name}}.name_required", "name is required")
}

// Err{{.NameTitle}}AlreadyExists indicates a unique constraint violation (e.g., duplicate name).
func Err{{.NameTitle}}AlreadyExists() *sharederr.DomainError {
	return sharederr.New(sharederr.CodeAlreadyExists, "{{.Name}}.already_exists", "{{.Name}} already exists")
}

// ErrInvalid{{.NameTitle}}State indicates the entity is in an invalid state for the requested operation.
// Example: attempting to mutate a soft-deleted entity.
func ErrInvalid{{.NameTitle}}State() *sharederr.DomainError {
	return sharederr.New(sharederr.CodeInvalidArgument, "{{.Name}}.invalid_state", "{{.Name}} is in an invalid state")
}

