package app

import (
	"context"
	"fmt"
	"log/slog"

	"{{.GoModule}}/internal/modules/{{.Name}}/domain"
	"{{.GoModule}}/internal/shared/auth"
	"{{.GoModule}}/internal/shared/events"
	"{{.GoModule}}/internal/shared/netutil"
)

// Create{{.NameTitle}}Cmd holds input for creating a {{.Name}}.
type Create{{.NameTitle}}Cmd struct {
	Name string
}

// Create{{.NameTitle}}Handler handles {{.Name}} creation.
type Create{{.NameTitle}}Handler struct {
	repo domain.{{.NameTitle}}Repository
	bus  events.EventPublisher
}

// NewCreate{{.NameTitle}}Handler constructs the handler.
func NewCreate{{.NameTitle}}Handler(repo domain.{{.NameTitle}}Repository, bus events.EventPublisher) *Create{{.NameTitle}}Handler {
	return &Create{{.NameTitle}}Handler{repo: repo, bus: bus}
}

// Handle creates a new {{.Name}}.
func (h *Create{{.NameTitle}}Handler) Handle(ctx context.Context, cmd Create{{.NameTitle}}Cmd) (*domain.{{.NameTitle}}, error) {
	entity, err := domain.New{{.NameTitle}}(cmd.Name)
	if err != nil {
		return nil, err
	}

	if err := h.repo.Create(ctx, entity); err != nil {
		return nil, fmt.Errorf("creating {{.Name}}: %w", err)
	}

	// Publish domain event after successful DB write (fire-and-forget: log but don't fail).
	if err := h.bus.Publish(ctx, domain.Topic{{.NameTitle}}Created, domain.{{.NameTitle}}CreatedEvent{
		{{.NameTitle}}ID: string(entity.ID()),
		Name:            entity.Name(),
		ActorID:         auth.ActorIDFromContext(ctx),
		IPAddress:       netutil.GetClientIP(ctx),
		At:              entity.CreatedAt(),
	}); err != nil {
		slog.ErrorContext(ctx, "failed to publish {{.Name}}.created event",
			"{{.Name}}_id", string(entity.ID()), "err", err)
	}

	return entity, nil
}
