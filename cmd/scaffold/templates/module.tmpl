package {{.NamePackage}}

import (
	"context"

	"{{.GoModule}}/internal/modules/{{.Name}}/adapters/grpc"
	"{{.GoModule}}/internal/modules/{{.Name}}/adapters/postgres"
	"{{.GoModule}}/internal/modules/{{.Name}}/app"
	"{{.GoModule}}/internal/modules/{{.Name}}/domain"
	"{{.GoModule}}/internal/shared/config"
	"github.com/labstack/echo/v4"
	"github.com/redis/go-redis/v9"
	"go.uber.org/fx"
)

// Module provides the {{.Name}} module to the Fx container.
// EventPublisher (events.EventPublisher) is resolved automatically by Fx from the shared bus provider.
var Module = fx.Module("{{.Name}}",
	fx.Provide(
		fx.Annotate(
			postgres.NewPg{{.NameTitle}}Repository,
			fx.As(new(domain.{{.NameTitle}}Repository)),
		),
	),
	fx.Provide(app.NewCreate{{.NameTitle}}Handler),
	fx.Provide(app.NewGet{{.NameTitle}}Handler),
	fx.Provide(app.NewList{{.NamePluralTitle}}Handler),
	fx.Provide(app.NewUpdate{{.NameTitle}}Handler),
	fx.Provide(app.NewDelete{{.NameTitle}}Handler),
	fx.Provide(grpc.New{{.NameTitle}}ServiceHandler),
	fx.Invoke(register{{.NameTitle}}Routes),
	// TODO: Add event subscribers when needed. Example:
	// fx.Provide(fx.Annotate(
	//     provideEventHandlers,
	//     fx.ResultTags(`group:"event_handlers"`),
	// )),
	// See internal/modules/user/module.go for subscriber wiring reference.
)

// register{{.NameTitle}}Routes creates a shutdown-aware context for the Auth middleware
// and delegates to grpc.RegisterRoutes. The context is cancelled during fx shutdown,
// ensuring the Auth middleware's background eviction goroutine exits cleanly.
func register{{.NameTitle}}Routes(lc fx.Lifecycle, e *echo.Echo, handler *grpc.{{.NameTitle}}ServiceHandler, cfg *config.Config, rdb *redis.Client) {
	ctx, cancel := context.WithCancel(context.Background())
	lc.Append(fx.Hook{
		OnStop: func(_ context.Context) error {
			cancel()
			return nil
		},
	})
	grpc.RegisterRoutes(ctx, e, handler, cfg, rdb)
}
